{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "yourdomain.com",
  "Cors": {
    "AllowedOrigins": [ "https://yourdomain.com" ]
  },
  "Upload": {
    "MaxFileSizeMb": 10
  },
  "RateLimit": {
    "RequestsPerMinute": 20
  }
}
